# ─────────────────────────────────────────────────────────────
# Rentauto - Frontend environment variables (Vite)
# ─────────────────────────────────────────────────────────────
# All variables exposed to the browser MUST be prefixed with VITE_.
# NEVER put secret keys here (no service role, no Stripe secret,
# no Twilio secret, etc.). Secrets belong in Supabase Edge Function
# secrets or your server environment only.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key
VITE_SUPABASE_PROJECT_ID=your-project-ref

# Public URL where the deployed app lives (used for share links, OAuth redirects)
VITE_APP_URL=https://yourdomain.com
